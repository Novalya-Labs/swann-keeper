# ==========================================================================
# Swann — environment configuration (development / standalone)
#
# Copy to `.env` and fill in. When running as a Home Assistant add-on these
# values come from /data/options.json instead (see src/config.ts) and this
# file is NOT used. Never commit a filled-in .env.
# ==========================================================================

# --- Discord -------------------------------------------------------------
# Bot token (Developer Portal > Bot). KEEP SECRET.
DISCORD_TOKEN=
# Application (client) ID — used to register slash commands.
DISCORD_APP_ID=
# Guild ID for instant guild-scoped slash command registration during dev.
# Leave empty to register globally (can take up to 1h to propagate).
DISCORD_GUILD_ID=

# --- Mistral AI ----------------------------------------------------------
# API key for chat (function-calling) + Voxtral transcription. KEEP SECRET.
MISTRAL_API_KEY=
# Chat model for the agentic tool-calling loop.
MISTRAL_CHAT_MODEL=mistral-medium-3-5
# Voxtral model for voice transcription.
MISTRAL_TRANSCRIBE_MODEL=voxtral-mini-latest

# --- Picovoice (wake word) ----------------------------------------------
# AccessKey from console.picovoice.ai. KEEP SECRET.
PICOVOICE_ACCESS_KEY=
# Path to the trained "Swann" keyword file (.ppn, Raspberry Pi platform).
PICOVOICE_KEYWORD_PATH=/data/Swann_en_raspberry-pi_v3_0_0.ppn
# Wake-word sensitivity 0..1 (higher = more detections, more false positives).
PICOVOICE_SENSITIVITY=0.6
# Path to the Silero VAD model used by sherpa-onnx.
SILERO_VAD_PATH=/data/silero_vad.onnx

# --- Lavalink ------------------------------------------------------------
# Host/port/password of the Lavalink v4 node. In the HA add-on this is
# localhost:2333 (Lavalink runs in the same container via s6-overlay).
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
# "true" if the Lavalink node uses TLS (wss/https), otherwise "false".
LAVALINK_SECURE=false

# Optional: Spotify metadata via LavaSrc (used in Lavalink application.yml).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Admin / Ingress web UI ---------------------------------------------
# Port the admin server binds to. Must equal ingress_port in config.yaml.
INGRESS_PORT=8099
# Bind address. 0.0.0.0 so the HA Ingress gateway (172.30.32.2) can reach it.
ADMIN_BIND_ADDRESS=0.0.0.0
# "true" to restrict to the HA Ingress gateway IP only (production default).
# Set "false" for local dev when hitting the UI directly from a browser.
ADMIN_INGRESS_ONLY=true

# --- Behaviour / runtime -------------------------------------------------
# Log level: trace | debug | info | warning | error
LOG_LEVEL=info
# Text wake phrase that triggers the NL agent from chat messages.
TEXT_WAKE_PHRASE="Hey Swann"
# Default playback volume 0..100.
DEFAULT_VOLUME=80
